            "label": "2026-04-14_10-27-55",
            "content": "package main\n\nimport (\n\t\"bufio\"\n\t\"fmt\"\n\t\"os\"\n\t\"strconv\"\n\t\"strings\"\n)\n\nfunc processa(vet []int) {\n\t\n\t// 1. defina o ponto de parada\n\tvar tam int = len(vet)\n\tif(len(vet) <= 1) {\n\t\tfmt.Printf(\"[ \");\n\t\tfor i:= 0; i < tam; i++{\n\t\tfmt.Printf(\"%d \", vet[i])\n\n\t\t}\n\t\tfmt.Println(\"]\")\n\t\treturn\n\t}\n\t// 2. monte o vetor auxiliar com os resultados das somas\n\t\n\tsoma := make([]int, tam-1)\n\tfor i := 0; i < tam -1; i++{\n\t\tsoma[i] = vet[i] + vet[i+1]\n\t}\n\t\n\n\t// 3. chame recursivamente a fun\u00e7\u00e3o processa para o vetor auxiliar\n\tprocessa(soma)\n\t// 4. imprima o vetor original\n\tfmt.Printf(\"[ \");\n\tfor i:= 0; i < tam; i++{\n\t\tfmt.Printf(\"%d \", vet[i])\n\n\t}\n\tfmt.Println(\"]\")\n}\n\nfunc main() {\n\tscanner := bufio.NewScanner(os.Stdin)\n\tif !scanner.Scan() {\n\t\treturn\n\t}\n\tline := scanner.Text()\n\tparts := strings.Fields(line)\n\tvet := []int{}\n\tfor _, part := range parts {\n\t\tif value, err := strconv.Atoi(part); err == nil {\n\t\t\tvet = append(vet, value)\n\t\t}\n\t}\n\tprocessa(vet)\n}\n\nfunc Join[T any](v []T, sep string) string {\n\tif len(v) == 0 {\n\t\treturn \"\"\n\t}\n\ts := \"\"\n\tfor i, x := range v {\n\t\tif i > 0 {\n\t\t\ts += sep\n\t\t}\n\t\ts += fmt.Sprintf(\"%v\", x)\n\t}\n\treturn s\n}\n",
