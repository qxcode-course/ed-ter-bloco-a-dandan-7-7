            "label": "2026-04-14_11-59-29",
            "content": "package main\nimport \"fmt\"\nfunc main() {\n    var total, possui int\n    fmt.Scanf(\"%d\", &total)\n    fmt.Scanf(\"%d\", &possui)\n    var figurinhas = make([]int, possui)\n    for i := 0; i < possui; i++ {\n        fmt.Scanf(\"%d\", &figurinhas[i])\n    }\n\n    b:= 0\n    for i := 1; i<possui;i++{\n        if figurinhas[i - 1] == figurinhas[i]{\n            fmt.Printf(\"%d \", figurinhas[i])\n            b = 1\n        }\n    }\n    if b == 0{\n        fmt.Printf(\"N\")\n    }\n    fmt.Println()\n\n    \n    var pos int = 0\n    ver := 0\n    faltantes := make([]int, total - possui)\n    k := 0\n    for i := 0; i <= total; i++{\n        pos = 0\n        for j := 0; j < possui; j++{\n            if i == figurinhas[j]{\n                pos = 1\n                ver = 1\n                \n\n            }\n\n        }\n        if pos == 0 && i != 0{\n            faltantes[k] = i\n            k++\n            \n        }\n    }\n    if ver == 0{\n        fmt.Printf(\"N\")\n    } else{\n    for i := 0; i < total - possui; i++{\n        fmt.Printf(\"%d \", faltantes[i])\n        if( i < total - possui - 1){\n            fmt.Printf(\" \")\n        }\n    }\n}\n    \n    fmt.Println()\n\n}\n",
