{"ts":1783208733,"hash":"e74079791a656c9e553db6018e0740013d3ab4b1deef2d893589d87ca8e57f52","mode":"diff","ops":[{"tag":"replace","a1":14,"a2":15,"text":"\tif corOri == color{\n\t\treturn image\n\t}\n\n\tvar pintar func(sr int, sc int)\n\tpintar = func(sr int, sc int) {\n\t\tif sr < 0 || sc < 0 || sr >= len(image) || sc >= len(image[0]) {\n\t\t\treturn\n\t\t}\n\t\tif image[sr][sc] != corOri {\n\t\t\treturn\n\t\t}\n\t\timage[sr][sc] = color\n\t\tpintar(sr+1, sc)\n\t\tpintar(sr-1, sc)\n\t\tpintar(sr, sc+1)\n\t\tpintar(sr, sc-1)\n\t}\n\n\tpintar(sr, sc)\n\treturn image\n}\n"}]}
